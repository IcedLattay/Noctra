<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_companion_gradient">

    <!-- Top Demo Banner -->
    <LinearLayout
        android:id="@+id/tvDemoBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEMO:"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnXpMinus"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:padding="0dp"
            android:text="-XP"
            android:textColor="@color/noctra_yellow"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnXpPlus"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:padding="0dp"
            android:text="+XP"
            android:textColor="@color/noctra_yellow"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnSeedData"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:text="[RESET]"
            android:textColor="@color/noctra_yellow"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Top Token Pill -->
    <LinearLayout
        android:id="@+id/tokenContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_token_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvDemoBanner">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/dream_token_icon" />

        <TextView
            android:id="@+id/tvTokenBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/noctra_text_dark"
            android:textSize="18sp"
            tools:text="50" />
    </LinearLayout>

    <!-- Main Content Container shifted upwards -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/bottomSpacer"
        app:layout_constraintTop_toBottomOf="@+id/tokenContainer"
        app:layout_constraintVertical_bias="0.1">

        <!-- Shleepy Display Area -->
        <FrameLayout
            android:id="@+id/shleepyFrame"
            android:layout_width="260dp"
            android:layout_height="260dp">

            <!-- Shleepy Shadow -->
            <View
                android:layout_width="120dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="24dp"
                android:alpha="0.15"
                android:background="@drawable/bg_token_pill" />

            <!-- Base Shleepy - Fixed size via padding -->
            <ImageView
                android:id="@+id/ivShleepy"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_description_shleepy"
                android:padding="40dp"
                android:scaleType="centerInside"
                android:src="@drawable/shleepy_depleted" />

            <!-- Equipped Layers -->
            <ImageView
                android:id="@+id/ivEquippedOutfitCompanion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="40dp"
                android:scaleType="centerInside"
                android:translationY="10dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivEquippedHatCompanion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="40dp"
                android:scaleType="centerInside"
                android:translationY="-55dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivEquippedAccessoryCompanion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="40dp"
                android:scaleType="centerInside"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Evolution Stage Pill -->
        <TextView
            android:id="@+id/tvStageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:background="@drawable/bg_stage_pill"
            android:fontFamily="sans-serif-black"
            android:paddingStart="24dp"
            android:paddingTop="8dp"
            android:paddingEnd="24dp"
            android:paddingBottom="8dp"
            android:textColor="@color/noctra_text_dark"
            android:textSize="18sp"
            tools:text="Energized" />

        <!-- Sleep Quality Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvSleepQualityCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvSleepQualityNoData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/companion_no_sleep_data"
                    android:textColor="@color/noctra_text_dark"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/groupSleepQualitySuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:id="@+id/miniGaugeContainer"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ProgressBar
                            android:id="@+id/pbSleepGaugeMini"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="79"
                            android:progressDrawable="@drawable/progress_circular_gauge" />

                        <TextView
                            android:id="@+id/tvSleepScoreMini"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/noctra_purple_dark"
                            android:textSize="12sp"
                            tools:text="79" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvSleepScoreLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/companion_last_night_sleep"
                        android:textColor="@color/noctra_text_dark"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toTopOf="@+id/tvSleepQualityStatus"
                        app:layout_constraintStart_toEndOf="@+id/miniGaugeContainer"
                        app:layout_constraintTop_toTopOf="@+id/miniGaugeContainer"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvSleepQualityStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/companion_good_sleep_quality"
                        android:textColor="@color/noctra_purple_light"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="@+id/miniGaugeContainer"
                        app:layout_constraintStart_toStartOf="@+id/tvSleepScoreLabel"
                        app:layout_constraintTop_toBottomOf="@+id/tvSleepScoreLabel" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- XP / Sleep Points Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvXpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvXpTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/companion_sleep_points"
                    android:textColor="@color/noctra_text_dark"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvXpValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/noctra_text_dark"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="30 XP" />

                <ProgressBar
                    android:id="@+id/pbXpProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="12dp"
                    android:progressDrawable="@drawable/progress_xp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvXpTitle"
                    tools:progress="60" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Customize Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnCustomize"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardBackgroundColor="@color/noctra_purple_soft"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="24dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/companion_customize_button"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:contentDescription="@string/content_description_mini_shleepy"
                    android:scaleType="centerInside"
                    android:src="@drawable/shleepyicon"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Empty space for Bottom Nav -->
    <View
        android:id="@+id/bottomSpacer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
