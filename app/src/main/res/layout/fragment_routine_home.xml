<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Title: My Routines -->
    <TextView
        android:id="@+id/tv_routine_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="My Routines"
        android:textColor="@color/noctra_purple_dark"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppinsbold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtitle: 3 activities • 23 minutes total -->
    <TextView
        android:id="@+id/tv_routine_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:textColor="#666666"
        android:textSize="13sp"
        android:fontFamily="@font/poppinsregular"
        tools:text="3 activities • 23 minutes total"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_routine_title" />

    <!-- Window time hint: shown in BeforeWindow state -->
    <TextView
        android:id="@+id/tv_window_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/noctra_purple_dark"
        android:textSize="12sp"
        android:fontFamily="@font/poppinsregular"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="Routine opens at 10:00 PM"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_routine_subtitle" />

    <!-- Streak Badge -->
    <LinearLayout
        android:id="@+id/ll_streak_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_timer_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_routine_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_routine_subtitle">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_alarm_clock"
            android:contentDescription="streak"
            android:tint="#FF6B2C" />

        <TextView
            android:id="@+id/tv_streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#FF6B2C"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppinsbold"
            tools:text="0 day streak" />

    </LinearLayout>

    <!-- Activity Cards Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_activity_cards"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_window_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_begin_routine"
        tools:listitem="@layout/item_activity_card_home" />

    <!-- Begin Routine Button (InWindow state only) -->
    <Button
        android:id="@+id/btn_begin_routine"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_primary_button"
        android:text="Begin Routine"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppinsbold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Edit Routine Button (BeforeWindow state only) -->
    <Button
        android:id="@+id/btn_edit_routine"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_primary_button"
        android:text="Edit Routine"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppinsbold"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Completed State -->
    <LinearLayout
        android:id="@+id/layout_completed_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_routine_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_begin_routine">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_alarm_clock"
            android:contentDescription="Completed" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Routine Complete!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/noctra_purple_dark"
            android:fontFamily="@font/poppinsbold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Great job tonight. See you tomorrow!"
            android:textSize="14sp"
            android:textColor="#666666"
            android:fontFamily="@font/poppinsregular" />

        <Button
            android:id="@+id/btn_force_reset_demo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Reset for Demo"
            android:textColor="@color/noctra_purple_dark"
            style="@style/Widget.Material3.Button.TextButton"
            android:fontFamily="@font/poppinsmedium" />

    </LinearLayout>

    <!-- No Routine State -->
    <LinearLayout
        android:id="@+id/layout_no_routine_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_routine_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_begin_routine">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_alarm_clock"
            android:contentDescription="No routine" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No routine set up yet"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/noctra_purple_dark"
            android:fontFamily="@font/poppinsbold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Complete onboarding to configure your routine."
            android:textSize="14sp"
            android:textColor="#666666"
            android:fontFamily="@font/poppinsregular" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>