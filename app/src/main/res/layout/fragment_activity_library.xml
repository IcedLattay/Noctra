<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F4FF">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header row: mascot + title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/shleepylogo"
                    android:contentDescription="Shleepy mascot" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose Your Activities"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#16056E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Step 2 of 3"
                        android:textSize="13sp"
                        android:textColor="#7B6FA0" />

                </LinearLayout>
            </LinearLayout>

            <!-- Selection banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFDE7"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSelectionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 selected — add 3 more"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#16056E" />

                    <TextView
                        android:id="@+id/tvSelectionHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exactly 3 activities required"
                        android:textSize="13sp"
                        android:textColor="#5C4A00"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3-segment progress bar -->
            <LinearLayout
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <View
                    android:id="@+id/progressSegment1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_segment_active" />

                <View
                    android:id="@+id/progressSegment2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_segment_inactive" />

                <View
                    android:id="@+id/progressSegment3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_segment_inactive" />

            </LinearLayout>

            <!-- Error state (hidden by default) -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="Failed to load activities. Please try again."
                android:textColor="#B00020"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Activity grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActivities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom buttons — fixed outside scroll -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:background="#F5F4FF">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Select exactly 3 activities"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#5C25F0"
            app:cornerRadius="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back"
            android:textSize="15sp"
            android:textColor="#7B6FA0"
            app:backgroundTint="#E0DCF0"
            app:cornerRadius="24dp" />

    </LinearLayout>

</LinearLayout>