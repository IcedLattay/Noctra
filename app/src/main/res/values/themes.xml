<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Noctra" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/noctra_purple_light</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Theme.Noctra" parent="Base.Theme.Noctra" />

    <!-- Debug Panel Styles -->
    <style name="DebugSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/poppinsbold</item>
        <item name="android:textColor">@color/noctra_purple_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="DebugCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="DebugCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="DebugButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/poppinsbold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/noctra_purple_light</item>
        <item name="strokeColor">@color/noctra_purple_light</item>
    </style>

    <style name="DebugButton.Destructive" parent="DebugButton">
        <item name="android:textColor">@color/noctra_destructive_red</item>
        <item name="strokeColor">@color/noctra_destructive_red</item>
        <item name="rippleColor">#20FF0000</item>
    </style>

    <style name="DebugDescription">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:fontFamily">@font/poppinsregular</item>
        <item name="android:textColor">#666666</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="DebugDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#EEEEEE</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>
</resources>