<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/routineHomeFragment">

    <!-- Bottom Nav Tabs -->
    <fragment
        android:id="@+id/routineHomeFragment"
        android:name="com.noctra.app.ui.routine.home.RoutineHomeFragment"
        android:label="Routine">
        <action
            android:id="@+id/action_routineHomeFragment_to_routineStartFragment"
            app:destination="@id/routineStartFragment" />
    </fragment>

    <fragment
        android:id="@+id/analyticsDashboardFragment"
        android:name="com.noctra.app.ui.analytics.AnalyticsDashboardFragment"
        android:label="Progress" />

    <fragment
        android:id="@+id/companionFragment"
        android:name="com.noctra.app.ui.companion.CompanionFragment"
        android:label="Companion" />

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.noctra.app.ui.profile.UserProfileFragment"
        android:label="Profile" />

    <!-- Routine Flow -->
    <fragment
        android:id="@+id/routineStartFragment"
        android:name="com.noctra.app.ui.routine.home.RoutineStartFragment"
        android:label="Start Routine">
        <action
            android:id="@+id/action_routineStartFragment_to_breathingActivityFragment"
            app:destination="@id/breathingActivityFragment" />
        <action
            android:id="@+id/action_routineStartFragment_to_audioscapeActivityFragment"
            app:destination="@id/audioscapeActivityFragment" />
        <action
            android:id="@+id/action_routineStartFragment_to_gratitudeJournalingActivityFragment"
            app:destination="@id/gratitudeJournalingActivityFragment" />
        <action
            android:id="@+id/action_routineStartFragment_to_genericTimerActivityFragment"
            app:destination="@id/genericTimerActivityFragment" />
    </fragment>

    <!-- Execution Screens (no inter-activity actions — direct nav by ID) -->
    <fragment
        android:id="@+id/breathingActivityFragment"
        android:name="com.noctra.app.ui.routine.execution.activities.BreathingActivityFragment"
        android:label="Breathing" />

    <fragment
        android:id="@+id/audioscapeActivityFragment"
        android:name="com.noctra.app.ui.routine.execution.activities.AudioscapeActivityFragment"
        android:label="Audio" />

    <fragment
        android:id="@+id/gratitudeJournalingActivityFragment"
        android:name="com.noctra.app.ui.routine.execution.activities.GratitudeJournalingActivityFragment"
        android:label="Journaling" />

    <fragment
        android:id="@+id/genericTimerActivityFragment"
        android:name="com.noctra.app.ui.routine.execution.activities.GenericTimerActivityFragment"
        android:label="Activity" />

    <!-- 5-Second Transition -->
    <fragment
        android:id="@+id/timesUpTransitionFragment"
        android:name="com.noctra.app.ui.routine.execution.TimesUpTransitionFragment"
        android:label="Time's Up" />

    <!-- Completion Overlay -->
    <fragment
        android:id="@+id/routineCompletionOverlayFragment"
        android:name="com.noctra.app.ui.routine.RoutineCompletionOverlayFragment"
        android:label="Complete">
        <action
            android:id="@+id/action_routineCompletionOverlayFragment_to_companionFragment"
            app:destination="@id/companionFragment" />
    </fragment>

    <!-- Global Actions -->
    <action
        android:id="@+id/action_global_routineHomeFragment"
        app:destination="@id/routineHomeFragment"
        app:popUpTo="@id/routineHomeFragment"
        app:popUpToInclusive="true" />

</navigation>